# ============================================================
# 宏曦标书 (HongXi Bidding) — Docker 部署环境配置
# Copy this file to .env and adjust values for your deployment.
# ============================================================

# --- Application ---
APP_NAME=宏曦标书
APP_VERSION=0.1.0
DEBUG=false

# --- Database ---
# Docker 内部使用，一般无需修改
DATABASE_URL=postgresql+asyncpg://hongxi:hongxi123@db:5432/hongxi_bid
DATABASE_URL_SYNC=postgresql+psycopg2://hongxi:hongxi123@db:5432/hongxi_bid
POSTGRES_USER=hongxi
POSTGRES_PASSWORD=hongxi123
POSTGRES_DB=hongxi_bid

# --- Auth (务必修改!) ---
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- AI Provider: deepseek / openai / tongyi ---
AI_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenAI (可选)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 通义千问 (可选)
TONGYI_API_KEY=
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TONGYI_MODEL=qwen3.7-plus

# AI 参数
AI_MODEL_OVERRIDE=
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# --- File paths (Docker 内部路径，不要修改) ---
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs
TEMPLATE_DIR=/app/templates

# --- Vector Store ---
VECTOR_STORE_ENABLED=true
CHROMA_PERSIST_DIR=/app/chroma_data
EMBEDDING_MODEL=/app/bge-base-zh-v1.5

# --- CORS (替换为服务器实际 IP 或域名) ---
CORS_ORIGINS=["http://localhost:8888"]

# --- Notification Webhooks (可选) ---
WECOM_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
