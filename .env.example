# 宏曦标书 (HongXi Bidding) — Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# Application
APP_NAME=宏曦标书
APP_VERSION=0.1.0
DEBUG=false

# Database (async + sync)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hongxi_bidding
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/hongxi_bidding

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI / DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# File paths
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
TEMPLATE_DIR=templates

# Notification webhooks (optional)
WECOM_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=

# CORS origins (JSON list)
CORS_ORIGINS=["http://localhost:5173"]
